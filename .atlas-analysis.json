  "keyFeatures": [
    "IPTV content management for VODs and Series",
    "Download management with aria2 integration",
    "Fast content search with MeiliSearch",
    "Watchlist and favorites tracking",
    "Automatic episode monitoring and downloads",
    "Multi-user access control",
    "Real-time download monitoring",
    "Xtream Codes API integration"
  ],
  "publicApiSurface": [
    "GET /movies - Browse movies",
    "GET /movies/{id} - View movie details",
    "GET /movies/{id}/download - Download movie",
    "GET /series - Browse series",
    "GET /series/{id} - View series details",
    "POST /series/{id}/download - Batch download episodes",
    "GET /downloads - View downloads",
    "GET /watchlist - View watchlist",
    "POST /search - Search content",
    "SyncMedia - Sync content from Xtream Codes",
    "DownloadMedia - Queue media for download",
    "ScanSeriesForNewEpisodes - Auto-download new episodes"
  ]
